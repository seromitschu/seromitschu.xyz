---
// src/pages/blog/index.astro
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import Footer from '../../components/Footer.astro';

const name = import.meta.env.PUBLIC_NAME;
const LINKS = {
  GITHUB: import.meta.env.LINK_GITHUB,
  SPOTIFY: import.meta.env.LINK_SPOTIFY,
  LINKEDIN: import.meta.env.LINK_LINKEDIN,
  DISCORD: import.meta.env.LINK_DISCORD
};

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const formatDate = (date: Date) => {
  return date.toLocaleDateString('tr-TR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};
---

<Layout title={`${name}`}>
  {/* Ana sayfa ile aynı ambient glow ve start-sequence yapısı */}
  <div id="ambient-glow" class="ambient-glow"></div>

  <div id="app-content" class="start-sequence">
    {/* Genişlik ve iç boşluklar index.astro ile birebir eşitlendi */}
    <main class="minimal-container">
      
      {/* Blog başlık alanı animasyon dizisinin ilk elemanı */}
      <section class="blog-section word delay-1">
        <div class="blog-header-block">
          <div class="title-area">
            <h2 class="section-title">Yazılar</h2>
            <span class="blog-counter">[Toplam Yazı: {posts.length}]</span>
          </div>
        </div>

        {/* Yazı listesi animasyon dizisinin ikinci elemanı */}
        <div class="blog-feed word delay-2">
          {posts.length === 0 ? (
            <p class="no-posts liquid-glass-effect">// Henüz bir yazı yayınlanmadı...</p>
          ) : (
            posts.map((post) => (
              <article class="blog-card liquid-glass-effect">
                <a href={`/blog/${post.id}`} class="card-link">
                  <div class="card-meta">
                    <time class="meta-date" datetime={post.data.pubDate.toISOString()}>
                      {formatDate(post.data.pubDate)}
                    </time>
                    {post.data.tags && (
                      <div class="card-tags">
                        {post.data.tags.map((tag: string) => (
                          <span class="tag">#{tag.toLowerCase()}</span>
                        ))}
                      </div>
                    )}
                  </div>
                  
                  <h3 class="card-title">{post.data.title}</h3>
                  <p class="card-excerpt">{post.data.description || 'Açıklama bulunmuyor.'}</p>
                  
                  <div class="card-arrow">
                    <span class="arrow-text">OKUYUN</span>
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                      <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                  </div>
                </a>
              </article>
            ))
          )}
        </div>
      </section>
 <div class="word delay-4"><Footer name={name} links={LINKS} /></div>
    </main>
  </div>
</Layout>

<script>
  function initBlogGlassTracking() {
    if (window.innerWidth <= 768) return;
    const cards = document.querySelectorAll('.blog-card, .no-posts');
    cards.forEach(card => {
      const el = card as HTMLElement;
      el.addEventListener('mousemove', (e: any) => {
        const rect = el.getBoundingClientRect();
        el.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
        el.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
      });
    });
  }
  document.addEventListener('DOMContentLoaded', initBlogGlassTracking);
  document.addEventListener('astro:page-load', initBlogGlassTracking);
</script>

<style is:global>
  /* --- index.astro Şablonuyla Tam Eşitlenen Konteyner --- */
  .minimal-container {
    max-width: 840px;
    width: 100%;
    margin: 0 auto;
    /* Üst boşluk 1.5rem, yanlar clamp, alt boşluk Floating Navbar için 6rem */
    padding: 1.5rem clamp(1.2rem, 5vw, 1.5rem) 6rem clamp(1.2rem, 5vw, 1.5rem);
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* Giriş Animasyonları (Start Sequence Senkronizasyonu) */
  .word {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .start-sequence .word {
    opacity: 1;
    transform: translateY(0);
  }
  
  .delay-1 { transition-delay: 0.1s; }
  .delay-2 { transition-delay: 0.2s; }
  /* ---------------------------------------------------- */

  .blog-section { display: flex; flex-direction: column; width: 100%; box-sizing: border-box; }
  .blog-header-block { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 0.8rem; }
  .blog-header-block .title-area { display: flex; justify-content: space-between; align-items: center; }
  
  .section-title { 
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem; 
    text-transform: uppercase; 
    letter-spacing: 0.2em; 
    font-weight: 700; 
    color: #444446;
    margin: 0;
  }
  
  .blog-counter { font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: #444446; font-weight: 700; }
  .blog-feed { display: flex; flex-direction: column; gap: 0.6rem; width: 100%; }
  
  /* Liquid Glass Efektleri */
  .liquid-glass-effect { position: relative; background: rgba(255, 255, 255, 0.01); border: 1px solid rgba(255, 255, 255, 0.03); box-shadow: 0 4px 24px 0 rgba(0, 0, 0, 0.6); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); overflow: hidden; transition: border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
  .liquid-glass-effect::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: radial-gradient(600px circle at var(--mouse-x, -999px) var(--mouse-y, -999px), rgba(255, 255, 255, 0.03), transparent 40%); z-index: 3; pointer-events: none; }
  
  .blog-card { border-radius: 12px; }
  .blog-card:hover { border-color: rgba(255, 255, 255, 0.08); box-shadow: 0 12px 40px rgba(0, 0, 0, 0.8); transform: translateY(-1px); }
  .card-link { display: block; padding: 1.4rem 1.6rem; text-decoration: none; color: inherit; }
  .card-meta { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.5rem; }
  .meta-date { font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: #444446; font-weight: 700; }
  .card-tags { display: flex; gap: 0.4rem; }
  .tag { font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; color: #86868b; background: rgba(255, 255, 255, 0.04); padding: 0.1rem 0.4rem; border-radius: 4px; font-weight: 500; }
  .card-title { font-size: 1.05rem; font-weight: 700; color: #f5f5f7; letter-spacing: -0.01em; margin: 0 0 0.4rem 0; font-family: 'Inter Tight', -apple-system, sans-serif; }
  .card-excerpt { color: #86868b; font-size: 0.82rem; line-height: 1.5; margin: 0 0 1rem 0; }
  
  .card-arrow { display: flex; align-items: center; gap: 0.35rem; color: #636366; transition: color 0.3s cubic-bezier(0.16, 1, 0.3, 1), transform 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
  .arrow-text { font-family: 'JetBrains Mono', monospace; font-size: 0.58rem; font-weight: 700; letter-spacing: 0.05em; }
  .blog-card:hover .card-arrow { color: #30d158; transform: translateX(2px); }
  
  .no-posts { font-family: 'JetBrains Mono', monospace; color: #444446; font-size: 0.68rem; text-align: center; padding: 3rem 0; border-radius: 12px; }

  @media (max-width: 768px) { 
    .card-link { padding: 1.2rem; } 
    .card-title { font-size: 1rem; } 
    .blog-card:hover { transform: none !important; } 
  }
</style>
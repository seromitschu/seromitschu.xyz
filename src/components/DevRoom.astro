---
// src/components/DevRoom.astro
// GitHub REST/GraphQL API verileri için high-contrast dark mode ve liquid-glass entegrasyonlu bento tasarımı.
// Commit Haritası (Contribution Graph) entegrasyonu eklendi.
---

<section class="dev-section word delay-9">
    <div class="dev-header-block">
        <div class="title-area">
            <h2 class="section-title">Geliştirici Odası</h2>
        </div>
    </div>

    <div class="bento-profile-wrapper">
        <div class="bento-profile-card liquid-glass-effect">
            
            <div class="profile-main-flow">
                <div class="profile-left-container">
                    <a id="github-profile-link" href="#" target="_blank" class="profile-left-section">
                        <div class="avatar-container">
                            <img id="github-avatar" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" alt="Avatar" class="github-avatar-img"/>
                            <span id="github-status-dot" class="status-dot"></span>
                        </div>
                        <div class="profile-meta-info">
                            <div class="name-row">
                                <span id="github-username" class="github-name">-</span>
                                <span id="github-bio" class="github-bio-badge" style="display: none;"></span>
                            </div>
                            <div class="status-row-text">
                                <span id="github-status-text" class="github-status-txt">GITHUB</span>
                                <span id="github-status-detailed" class="github-status-detailed-txt"></span>
                            </div>
                        </div>
                    </a>
                </div>

                <a id="latest-push-link" href="#" target="_blank" class="current-push-card-link" style="display: none;">
                    <div class="current-push-card liquid-glass-effect">
                        <div class="icon-wrapper-live">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="#30d158" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="3"></circle>
                                <circle cx="4" cy="4" r="3"></circle>
                                <path d="M4 7v6"></path>
                            </svg>
                        </div>
                        <div class="current-push-details">
                            <div class="push-status">
                                <div id="github-radar" class="github-radar active">
                                    <span class="radar-dot"></span>
                                    <span class="radar-ring"></span>
                                </div>
                                <span id="live-push-status-text">SON AKTİVİTE</span>
                            </div>
                            <div class="push-info">
                                <span class="push-title" id="live-push-message">-</span>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
            
            <div class="profile-stats-section">
                <div class="stat-item">
                    <span class="stat-label">REPOLAR</span>
                    <span class="stat-value" id="stat-total-repos">-</span>
                </div>
                <div class="stat-item">
                    <span class="stat-label">TAKİPÇİ</span>
                    <span class="stat-value" id="stat-followers">-</span>
                </div>
                <div class="stat-item">
                    <span class="stat-label">YILDIZLAR</span>
                    <span class="stat-value" id="stat-total-stars">-</span>
                </div>
            </div>

        </div>
    </div>

    <!-- YENİ: Commit Haritası Bento Bloğu -->
    <div class="commit-graph-wrapper">
        <div class="commit-graph-card liquid-glass-effect">
            <div class="graph-header">
                <span class="graph-title">KATKILAR (SON 12 HAFTA)</span>
                <span class="graph-total-count" id="graph-total-commits">- commit</span>
            </div>
            <div class="graph-grid-container" id="github-contributions-grid">
                <div class="recent-loading">Harita yükleniyor...</div>
            </div>
        </div>
    </div>

    <div class="dev-room-content-layout">
        <div class="bento-side-column">
            <div class="bento-list-block">
                <h3 class="subsection-title">Son Aktiviteler</h3>
                <div class="bento-list-card liquid-glass-effect" id="recent-commits-container">
                    <div class="recent-loading">Yükleniyor...</div>
                </div>
            </div>
        </div>

        <div class="sub-dev-block">
            <h3 class="subsection-title">Öne Çıkan Projeler</h3>
            <div class="bento-seamless-grid" id="pinned-repos-grid"></div>
        </div>
    </div>
</section>

<script>
    let pollInterval: any = null;

    function initLiquidGlassTracking() {
        if (window.innerWidth <= 768) return;
        const cards = document.querySelectorAll('.liquid-glass-effect, .repo-node');
        cards.forEach(card => {
            const el = card as HTMLElement;
            el.addEventListener('mousemove', (e: any) => {
                const rect = el.getBoundingClientRect();
                el.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
                el.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
            });
        });
    }

    async function fetchGitHubData() {
        try {
            console.log("GitHub API verisi çekiliyor...");
            const res = await fetch('/api/github');
            if (!res.ok) throw new Error(`HTTP hatası! Durum: ${res.status}`);
            const data = await res.json();

            console.log("Gelen GitHub Verisi:", data);

            if (!data) return;

            // 1. Profil Senkronizasyonu
            if (data.profile) {
                const avatarImg = document.getElementById('github-avatar') as HTMLImageElement;
                if (avatarImg) avatarImg.src = data.profile.avatar_url || '';
                
                const usernameEl = document.getElementById('github-username');
                if (usernameEl) usernameEl.textContent = data.profile.login || '-';
                
                const link = document.getElementById('github-profile-link');
                if (link) link.setAttribute('href', data.profile.html_url || '#');

                const bioBadge = document.getElementById('github-bio');
                if (bioBadge) {
                    if (data.profile.bio) {
                        bioBadge.textContent = data.profile.bio;
                        bioBadge.style.display = 'inline-block';
                    } else {
                        bioBadge.style.display = 'none';
                    }
                }
                const dot = document.getElementById('github-status-dot');
                if (dot) dot.style.backgroundColor = '#30d158';
            }

            // 2. İstatistik Senkronizasyonu
            if (data.stats) {
                const totalReposEl = document.getElementById('stat-total-repos');
                const followersEl = document.getElementById('stat-followers');
                const totalStarsEl = document.getElementById('stat-total-stars');

                if (totalReposEl) totalReposEl.textContent = data.stats.public_repos ?? '0';
                if (followersEl) followersEl.textContent = data.stats.followers ?? '0';
                if (totalStarsEl) totalStarsEl.textContent = data.stats.total_stars ?? '0';
            }

            // 3. Canlı Aktivite Üst Kart Senkronizasyonu
            const linkWrapper = document.getElementById('latest-push-link') as HTMLElement;
            if (linkWrapper && data.latestCommit) {
                const commitDate = new Date(data.latestCommit.created_at || new Date());
                const now = new Date();
                const diffInMinutes = (now.getTime() - commitDate.getTime()) / (1000 * 60);

                if (diffInMinutes <= 30) {
                    linkWrapper.style.display = 'block';
                    linkWrapper.setAttribute('href', data.latestCommit.url || '#');
                    const messageEl = document.getElementById('live-push-message');
                    if (messageEl) messageEl.textContent = data.latestCommit.message || '-';
                    const detailedEl = document.getElementById('github-status-detailed');
                    if (detailedEl) detailedEl.textContent = ` - ${data.latestCommit.repoName || ''}`;
                } else {
                    linkWrapper.style.display = 'none';
                }
            }

            // YENİ: 3.5 Commit Haritası Veri Senkronizasyonu
            const graphGrid = document.getElementById('github-contributions-grid');
            const graphTotal = document.getElementById('graph-total-commits');
            
            if (graphGrid && data.contributions && data.contributions.length > 0) {
                let graphHtml = '<div class="contrib-squares">';
                let totalCount = 0;

                // API'den gelen verilerin [{ count: 0, level: 0 }, ...] şeklinde olduğunu varsayıyoruz.
                // Level değerleri high-contrast renk paletine (0, 1, 2, 3, 4) göre stilize edilir.
                data.contributions.forEach((day: any) => {
                    totalCount += day.count || 0;
                    graphHtml += `<div class="contrib-square lvl-${day.level || 0}" title="${day.count || 0} commit"></div>`;
                });

                graphHtml += '</div>';
                graphGrid.innerHTML = graphHtml;
                if (graphTotal) graphTotal.textContent = `${totalCount} commit`;
            } else if (graphGrid) {
                graphGrid.innerHTML = '<div class="recent-empty">Katkı verisi yüklenemedi.</div>';
            }

            // 4. Dikey Son Aktiviteler Listesi
            const commitsContainer = document.getElementById('recent-commits-container');
            if (commitsContainer) {
                if (data.commits && data.commits.length > 0) {
                    let commitsHtml = '<div class="side-list-wrapper">';
                    
                    for (const cm of data.commits) {
                        const safeMessage = cm.message ? cm.message.replace(/"/g, '&quot;') : '-';
                        const safeRepo = cm.repoName ? cm.repoName.replace(/"/g, '&quot;') : '';
                        const safeUrl = cm.url || '#';
                        const safeTime = cm.timeAgo || '';

                        commitsHtml += `
                            <a href="${safeUrl}" target="_blank" class="side-list-item">
                                <div class="side-item-icon-box">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#86868b" stroke-width="2">
                                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                        <polyline points="22 4 12 14.01 9 11.01"></polyline>
                                    </svg>
                                </div>
                                <div class="side-item-meta">
                                    <span class="side-item-name">${safeMessage}</span>
                                    <span class="side-item-sub">${safeRepo} • ${safeTime}</span>
                                </div>
                            </a>
                        `;
                    }
                    
                    commitsHtml += '</div>';
                    commitsContainer.innerHTML = commitsHtml;
                } else {
                    commitsContainer.innerHTML = '<div class="recent-empty">Kayıt bulunamadı.</div>';
                }
            }

            // 5. Projeler Grid Senkronizasyonu
            const grid = document.getElementById('pinned-repos-grid');
            if (grid && data.repos && data.repos.length > 0) {
                let htmlContent = '';
                data.repos.forEach((repo: any) => {
                    const langBadgeHtml = repo.language ? `
                        <div class="repo-meta-bottom">
                            <div class="repo-lang-row">
                                <span class="repo-lang-dot" style="background-color: ${repo.languageColor || '#86868b'}"></span>
                                <span class="repo-lang-text">${repo.language}</span>
                            </div>
                        </div>
                    ` : '';

                    htmlContent += `
                        <a href="${repo.html_url}" target="_blank" class="repo-node liquid-glass-effect" title="${repo.name}">
                            <div class="repo-content-top">
                                <div class="repo-meta-top">
                                    <span class="repo-title">${repo.name}</span>
                                    <div class="repo-stars">
                                        <svg width="10" height="10" viewBox="0 0 24 24" fill="#86868b">
                                            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                                        </svg>
                                        <span>${repo.stargazers_count}</span>
                                    </div>
                                </div>
                                <p class="repo-desc">${repo.description || 'Açıklama bulunmuyor.'}</p>
                            </div>
                            ${langBadgeHtml}
                        </a>
                    `;
                });

                grid.innerHTML = htmlContent;
                initLiquidGlassTracking();
            }
        } catch (e) {
            console.error("DOM eşleştirme hatası:", e);
        }
    }

    function setupLifecycle() {
        fetchGitHubData();
        if (pollInterval) clearInterval(pollInterval);
        pollInterval = setInterval(fetchGitHubData, 60000);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setupLifecycle);
    } else {
        setupLifecycle();
    }
    document.addEventListener('astro:page-load', setupLifecycle);
</script>

<style is:global>
    .section-title { font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.2em; font-weight: 700; color: #444446; }
    .subsection-title { font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.2em; font-weight: 700; color: #444446; margin-bottom: 1rem; }
    .dev-section { display: flex; flex-direction: column; gap: 2.5rem; width: 100%; box-sizing: border-box; }
    .sub-dev-block { width: 100%; min-width: 0; }
    .dev-header-block { display: flex; flex-direction: column; gap: 1rem; }
    
    .liquid-glass-effect { 
        position: relative; 
        background: rgba(255, 255, 255, 0.01); 
        border: 1px solid rgba(255, 255, 255, 0.03); 
        box-shadow: 0 4px 24px 0 rgba(0, 0, 0, 0.6); 
        backdrop-filter: blur(20px); 
        -webkit-backdrop-filter: blur(20px); 
        overflow: hidden; 
        transition: border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    
    .current-push-card-link { text-decoration: none; color: inherit; width: 100%; max-width: 340px; display: block; }
    .current-push-card-link:hover .liquid-glass-effect { border-color: rgba(255, 255, 255, 0.08); box-shadow: 0 12px 40px rgba(0, 0, 0, 0.8); }

    .bento-profile-wrapper { width: 100%; }
    .bento-profile-card { display: flex; justify-content: space-between; align-items: center; padding: 1.5rem 1.8rem; border-radius: 14px; gap: 2rem; }
    .profile-main-flow { display: flex; flex-direction: column; gap: 1rem; min-width: 0; flex: 1.3; width: 100%; }
    .profile-left-container { display: flex; align-items: center; width: 100%; }
    .profile-left-section { display: flex; align-items: center; gap: 1rem; text-decoration: none; color: inherit; min-width: 0; width: 100%; }
    .avatar-container { position: relative; width: 50px; height: 50px; flex-shrink: 0; }
    .github-avatar-img { width: 100%; height: 100%; border-radius: 10px; object-fit: cover; border: 1px solid rgba(255, 255, 255, 0.08); }
    .status-dot { position: absolute; bottom: -1px; right: -1px; width: 11px; height: 11px; border-radius: 50%; border: 2px solid #0a0a0c; background-color: #898989; }
    .profile-meta-info { display: flex; flex-direction: column; gap: 0.2rem; min-width: 0; flex: 1; }
    .name-row { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
    .github-name { font-size: 1.1rem; font-weight: 700; color: #f5f5f7; letter-spacing: -0.01em; }
    .github-bio-badge { font-family: -apple-system, BlinkMacSystemFont, sans-serif; font-size: 0.65rem; color: #86868b; max-width: 180px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .status-row-text { display: flex; align-items: center; font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; font-weight: 600; color: #86868b; }
    .github-status-txt { text-transform: uppercase; color: #86868b; }
    .github-status-detailed-txt { color: #30d158; font-family: -apple-system, BlinkMacSystemFont, sans-serif; font-weight: 500; text-transform: none; }
    
    .current-push-card { padding: 0.5rem 0.7rem; border-radius: 10px; width: 100%; display: flex; align-items: center; gap: 0.7rem; }
    .icon-wrapper-live { width: 34px; height: 34px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; background: rgba(48, 209, 88, 0.05); border: 1px solid rgba(48, 209, 88, 0.15); border-radius: 6px; }
    .current-push-details { display: flex; flex-direction: column; min-width: 0; flex: 1; }
    .push-status { display: flex; align-items: center; gap: 0.4rem; font-size: 0.52rem; font-weight: 700; color: #86868b; letter-spacing: 0.04rem; }
    .github-radar { position: relative; width: 7px; height: 7px; display: flex; align-items: center; justify-content: center; }
    .radar-dot { width: 4px; height: 4px; background-color: #30d158; border-radius: 50%; }
    .radar-ring { position: absolute; width: 100%; height: 100%; border: 1px solid #30d158; border-radius: 50%; opacity: 0; scale: 0.8; animation: radar-pulse 1.6s cubic-bezier(0.215, 0.610, 0.355, 1) infinite; }
    @keyframes radar-pulse { 0% { opacity: 0.8; scale: 0.6; } 100% { opacity: 0; scale: 2.4; } }
    .push-title { font-size: 0.8rem; font-weight: 600; color: #f5f5f7; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

    .profile-stats-section { display: flex; gap: 2rem; flex-shrink: 0; justify-content: flex-end; }
    .stat-item { display: flex; flex-direction: column; gap: 0.1rem; min-width: 75px; }
    .stat-label { font-family: 'JetBrains Mono', monospace; font-size: 0.55rem; color: #636366; letter-spacing: 0.12em; font-weight: 600; }
    .stat-value { font-size: 1.25rem; font-weight: 700; color: #f5f5f7; letter-spacing: -0.02em; }
    
    /* YENİ: Commit Haritası Stilleri */
    .commit-graph-wrapper { width: 100%; }
    .commit-graph-card { padding: 1.2rem 1.5rem; border-radius: 14px; display: flex; flex-direction: column; gap: 0.8rem; }
    .graph-header { display: flex; justify-content: space-between; align-items: center; }
    .graph-title { font-family: 'JetBrains Mono', monospace; font-size: 0.58rem; color: #636366; letter-spacing: 0.12em; font-weight: 600; }
    .graph-total-count { font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; color: #30d158; font-weight: 500; }
    .graph-grid-container { width: 100%; overflow-x: auto; padding-bottom: 2px; }
    .contrib-squares { display: flex; gap: 4px; flex-flow: column wrap; height: 60px; max-width: 100%; }
    .contrib-square { width: 6px; height: 6px; border-radius: 1px; transition: background-color 0.2s; }
    
    /* High-contrast karanlık mod commit renk tonları */
    .lvl-0 { background-color: rgba(255, 255, 255, 0.04); }
    .lvl-1 { background-color: #0e4429; }
    .lvl-2 { background-color: #006d32; }
    .lvl-3 { background-color: #26a641; }
    .lvl-4 { background-color: #39d353; }

    .dev-room-content-layout { display: grid; grid-template-columns: 240px 1fr; gap: 1.8rem; align-items: start; width: 100%; }
    .bento-side-column { display: flex; flex-direction: column; width: 100%; min-width: 0; }
    .bento-list-block { width: 100%; min-width: 0; }
    .bento-list-card { border-radius: 12px; padding: 0.8rem; }
    .recent-loading, .recent-empty { font-size: 0.65rem; color: #444446; font-family: 'JetBrains Mono', monospace; text-align: center; padding: 0.8rem 0; }
    
    .side-list-wrapper { display: flex; flex-direction: column; gap: 0.7rem; }
    .side-list-item { display: flex; align-items: flex-start; gap: 0.65rem; min-width: 0; text-decoration: none; color: inherit; padding: 0.3rem 0; transition: opacity 0.2s; }
    .side-list-item:hover { opacity: 0.7; }
    .side-item-icon-box { margin-top: 0.1rem; flex-shrink: 0; }
    .side-item-meta { display: flex; flex-direction: column; min-width: 0; flex: 1; }
    .side-item-name { font-size: 0.72rem; font-weight: 600; color: #f5f5f7; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.3; }
    .side-item-sub { font-size: 0.58rem; color: #636366; font-family: 'JetBrains Mono', monospace; margin-top: 0.15rem; }

    .bento-seamless-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 0.7rem; width: 100%; min-width: 0; }
    
    .repo-node { 
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        width: 100%; 
        min-height: 130px;
        padding: 1rem;
        border-radius: 10px; 
        text-decoration: none; 
        overflow: hidden;
        min-width: 0;
        box-sizing: border-box;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1); 
    }
    .repo-node:hover { border-color: rgba(255, 255, 255, 0.1); transform: translateY(-2px); }
    
    .repo-content-top { display: flex; flex-direction: column; width: 100%; min-width: 0; }
    .repo-meta-top { display: flex; justify-content: space-between; align-items: center; gap: 0.5rem; width: 100%; min-width: 0; }
    .repo-title { font-size: 0.82rem; font-weight: 700; color: #f5f5f7; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1; min-width: 0; }
    .repo-stars { display: flex; align-items: center; gap: 0.25rem; font-family: 'JetBrains Mono', monospace; font-size: 0.58rem; color: #86868b; flex-shrink: 0; }

    .repo-desc { font-size: 0.65rem; color: #86868b; line-height: 1.4; margin: 0.5rem 0 0.8rem 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; width: 100%; }

    .repo-meta-bottom { display: flex; align-items: center; width: 100%; min-width: 0; margin-top: auto; }
    .repo-lang-row { display: flex; align-items: center; gap: 0.35rem; min-width: 0; }
    .repo-lang-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
    .repo-lang-text { font-family: 'JetBrains Mono', monospace; font-size: 0.55rem; color: #636366; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    
    .liquid-glass-effect::before, .repo-node::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: radial-gradient(600px circle at var(--mouse-x, -999px) var(--mouse-y, -999px), rgba(255, 255, 255, 0.02), transparent 40%); z-index: 3; pointer-events: none; }

    @media (max-width: 1024px) { 
        .dev-room-content-layout { grid-template-columns: 1fr; gap: 2rem; } 
        .side-list-wrapper { flex-direction: column; overflow-x: visible; gap: 0.7rem; padding-bottom: 0; } 
        .side-list-item { flex-shrink: 1; width: 100%; background: transparent; padding: 0.3rem 0; border: none; } 
    }
    
    @media (max-width: 768px) { 
        .bento-profile-card { flex-direction: column; align-items: flex-start; gap: 1.25rem; padding: 1.2rem; } 
        .profile-main-flow { width: 100%; } 
        .profile-stats-section { width: 100%; display: flex; flex-wrap: wrap; gap: 1rem; border-top: 1px solid rgba(255, 255, 255, 0.04); padding-top: 1rem; justify-content: space-between; text-align: left; } 
        .stat-item { min-width: 65px; flex: 1; } 
        .stat-value { font-size: 1.15rem; } 
        .current-push-card-link { max-width: 100%; } 
    }

    @media (max-width: 480px) { 
        .bento-seamless-grid { grid-template-columns: 1fr; gap: 0.6rem; } 
        .repo-node:hover { transform: none !important; }
    }
</style>
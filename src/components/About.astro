---
// src/components/About.astro
---

<section class="about-section word delay-6">
    <h2 class="section-title">Hakkımda</h2>
    
    <div class="about-layout">
        <!-- SOL TARAF: Mobil ve Masaüstü Uyumlu Akışkan Metin Alanı -->
        <div class="about-text">
            <p>
                Tasarım ve kodun kesiştiği noktada, insanı yormayan temiz arayüzler üretmeye odaklanıyorum. 
                Gereksiz tüm süslemelerden arındırılmış, işlevsel ve performanslı web deneyimleri geliştirmek en büyük motivasyonum. 
                Şu anda <span class="age-inline-wrapper">ben <span id="age-number">0.000000000</span> yaşındayım</span> ve çalışmalarıma Samsun'da bir geliştirici olarak devam ediyorum.
            </p>
        </div>

        <!-- SAĞ TARAF: Tamamen Telefon ve Masaüstü Uyumlu Bütünleşik Apple Widget'ı -->
        <div class="apple-widget-container">
            <!-- Üst Katman: Harita Bölümü -->
            <div class="apple-map-card">
                <!-- public/apple-samsun-map.png görselin -->
                <div class="map-image-layer"></div>
                <div class="map-overlay"></div>
                
                <a href="https://maps.apple.com/?q=Samsun" target="_blank" rel="noopener noreferrer" class="map-interactive-overlay">
                </a>
            </div>
            
            <!-- Alt Katman: Boşluğu Dolduran Hava Durumu & Saat Paneli -->
            <div class="widget-status-bar">
                    <div class="map-content">
                        <div class="location-marker">
                            <div class="pulse-ring"></div>
                            <div class="marker-dot"></div>
                        </div>
                        <div class="location-info">
                            <span class="city-name">Samsun</span>
                            <span class="country-name">Türkiye</span>
                        </div>
                    </div>
                
                <!-- Canlı Akışkan Saat -->
                <div class="local-time">
                    <span class="time-label">YEREL SAAT</span>
                    <span id="live-clock">00:00:00</span>
                </div>
            </div>
        </div>
    </div>
</section>

<script is:inline>
    function initResponsiveWidgets() {
        const ageEl = document.getElementById('age-number');
        const clockEl = document.getElementById('live-clock');
        const birthDate = new Date('2006-01-23T00:00:00').getTime();

        function updateAge() {
            if (!ageEl) return;
            const now = Date.now();
            const ageInMilliseconds = now - birthDate;
            const ageInYears = ageInMilliseconds / (365.25 * 24 * 60 * 60 * 1000);
            ageEl.textContent = ageInYears.toFixed(9);
        }

        function updateClock() {
            if (!clockEl) return;
            const now = new Date();
            clockEl.textContent = now.toLocaleTimeString('tr-TR', {
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit',
                hour12: false
            });
        }

        // SPA geçiş korumaları
        if (window.aboutAgeInterval) clearInterval(window.aboutAgeInterval);
        if (window.aboutClockInterval) clearInterval(window.aboutClockInterval);

        window.aboutAgeInterval = setInterval(updateAge, 50);
        window.aboutClockInterval = setInterval(updateClock, 1000);
        
        updateAge();
        updateClock();
    }

    document.addEventListener("DOMContentLoaded", initResponsiveWidgets);
    document.addEventListener("astro:page-load", initResponsiveWidgets);
</script>

<style>
    /* Temel Bölüm Ayarları */
    .about-section {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .section-title { 
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.68rem; 
        text-transform: uppercase; 
        letter-spacing: 0.2em; 
        font-weight: 700; 
        color: #444446;
        margin-bottom: 0.1rem;
    }

    /* Gelişmiş Responsive Grid Düzeni */
    .about-layout {
        display: grid;
        grid-template-columns: 1fr 320px; /* Masaüstünde yan yana kusursuz dağılım */
        gap: 2.5rem;
        align-items: flex-start;
    }

    .about-text p { 
        font-size: 1rem; 
        line-height: 1.8; 
        color: #86868b; 
        font-weight: 400; 
        margin: 0;
    }

    /* Metin İçi Sayacın Kararlı Tasarımı */
    .age-inline-wrapper {
        color: #ffffff;
        font-weight: 500;
        white-space: nowrap; /* Sayıların mobilde alakasız yerlerden kırılmasını önler */
    }

    #age-number {
        font-family: 'JetBrains Mono', monospace;
        font-size: 1rem;
        letter-spacing: -0.01em;
        background: linear-gradient(180deg, #ffffff 0%, #a1a1a6 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* TELEFON UYUMLU INTEGRATED APPLE KAPSAYICI */
    .apple-widget-container {
        display: flex;
        flex-direction: column;
        width: 100%;
        max-width: 320px;
        gap: 4px; /* iOS 26 standardı ultra dar ara boşluk */
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        margin: 0 auto; /* Mobilde ortalanması gerekirse pürüzsüz durur */
    }

    /* iOS Liquid Glass Hover Efekti */
    .apple-widget-container:hover {
        transform: scale(1.012) translateY(-1px);
    }

    /* Üst Harita Bloğu */
    .apple-map-card {
        position: relative;
        width: 100%;
        height: 120px;
        background: #1c1c1e;
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 16px 16px 6px 6px; /* Alt panelle bütünleşik geçiş */
        overflow: hidden;
    }

    .map-image-layer {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: url('/samsun.png');
        background-size: cover;
        background-position: center 65%;
    }

    .map-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.06);
        pointer-events: none;
    }

    .map-interactive-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: flex-end;
        padding: 10px;
        text-decoration: none;
        z-index: 2;
    }

    .map-content {
        display: flex;
        align-items: center;
        gap: 9px;
        background: rgba(28, 28, 30, 0.75);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        padding: 5px 12px;
        border-radius: 10px;
        border: 1px solid rgba(255, 255, 255, 0.04);
        width: auto;
    }

    /* Mavi Apple Konum Pini */
    .location-marker {
        position: relative;
        width: 10px;
        height: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .marker-dot {
        width: 8px;
        height: 8px;
        background-color: #0a84ff;
        border-radius: 50%;
        border: 1.5px solid #ffffff;
        box-shadow: 0 0 10px rgba(10, 132, 255, 1);
        z-index: 2;
    }

    .pulse-ring {
        position: absolute;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background-color: rgba(10, 132, 255, 0.25);
        animation: mapPulse 3s cubic-bezier(0.16, 1, 0.3, 1) infinite;
        z-index: 1;
    }

    @keyframes mapPulse {
        0% { transform: scale(0.5); opacity: 0.9; }
        100% { transform: scale(2.4); opacity: 0; }
    }

    .location-info {
        display: flex;
        flex-direction: column;
        line-height: 1.15;
    }

    .city-name {
        color: #ffffff;
        font-size: 0.8rem;
        font-weight: 600;
        font-family: -apple-system, BlinkMacSystemFont, sans-serif;
    }

    .country-name {
        color: #86868b;
        font-size: 0.65rem;
        font-weight: 400;
        font-family: -apple-system, BlinkMacSystemFont, sans-serif;
    }

    /* Alt Durum Şeridi (Boşluk Doldurucu) */
    .widget-status-bar {
        width: 100%;
        background: #1c1c1e;
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 6px 6px 16px 16px; /* Alt köşeleri kapatan iOS kavisi */
        padding: 10px 14px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .weather-mini {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.72rem;
        color: #86868b;
        font-family: -apple-system, BlinkMacSystemFont, sans-serif;
        font-weight: 400;
    }

    .weather-icon {
        width: 11px;
        height: 11px;
        color: #ffd60a;
    }

    .local-time {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        line-height: 1.2;
    }

    .time-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.52rem;
        color: #636366;
        letter-spacing: 0.05em;
        font-weight: 700;
    }

    #live-clock {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        color: #ffffff;
        font-weight: 500;
    }

    /* TELEFON / MOBIL ERAN OPTİMİZASYONU (Sıkı Kurallar) */
    @media (max-width: 768px) {
        .about-layout {
            grid-template-columns: 1fr; /* Mobilde her şeyi dikey akışa zorlar */
            gap: 1.5rem; /* Gereksiz büyük boşlukları daraltır */
        }
        
        .apple-widget-container {
            max-width: 100%; /* Telefon ekranlarında sağdan soldan taşmayı tamamen önler, tam genişlik kazanır */
        }

        .about-text p {
            font-size: 0.95rem; /* Küçük ekranlarda daha konforlu okuma boyutu */
            line-height: 1.7;
        }
    }

    /* Animasyon Girişleri */
    .word {
        display: inline-block;
        opacity: 0;
        filter: blur(10px);
        transform: translateY(8px);
        animation: revealText 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @keyframes revealText {
        to { opacity: 1; filter: blur(0px); transform: translateY(0); }
    }
    .delay-6 { animation-delay: 0.38s; }
</style>
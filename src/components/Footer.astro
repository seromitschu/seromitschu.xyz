---
// src/components/Footer.astro
const name = import.meta.env.PUBLIC_NAME;
const LINK_GITHUB = import.meta.env.LINK_GITHUB;
const LINK_SPOTIFY = import.meta.env.LINK_SPOTIFY;
const LINK_LINKEDIN = import.meta.env.LINK_LINKEDIN;
const LINK_DISCORD = import.meta.env.LINK_DISCORD;
---
<footer class="site-footer word delay-8">
    <div class="footer-divider"></div>
    <div class="footer-content">
        <div class="footer-credits">
            made with <span class="animated-heart">❤️</span> by {name}
        </div>
        <div class="footer-links">
            <a href={`${LINK_SPOTIFY}`} target="_blank" class="footer-link-item">Spotify</a>
            <a href={`${LINK_DISCORD}`} target="_blank" class="footer-link-item">Discord</a>
            <a href={`${LINK_GITHUB}`} target="_blank" class="footer-link-item">GitHub</a>
            <a href={`${LINK_LINKEDIN}`} target="_blank" class="footer-link-item">LinkedIn</a>
        </div>
    </div>
</footer>

<style>
    .site-footer { margin-top: 2rem; width: 100%; display: flex; flex-direction: column; gap: 1.5rem; }
    .footer-divider { width: 100%; height: 1px; background: linear-gradient(90deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.01) 100%); }
    .footer-content { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1.2rem; }
    .footer-credits { font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; color: #444446; letter-spacing: -0.01em; display: flex; align-items: center; gap: 0.35rem; }
    .animated-heart { display: inline-block; animation: heartbeat 1.4s infinite cubic-bezier(0.215, 0.610, 0.355, 1); transform-origin: center; }

    @keyframes heartbeat {
        0% { transform: scale(1); }
        14% { transform: scale(1.24); }
        28% { transform: scale(1); }
        42% { transform: scale(1.20); }
        70% { transform: scale(1); }
    }

    .footer-links { display: flex; gap: 1.2rem; }
    .footer-link-item { font-size: 0.75rem; font-weight: 500; color: #86868b; text-decoration: none; transition: color 0.3s ease; }
    .footer-link-item:hover { color: #f5f5f7; }

    @media (max-width: 600px) {
        .footer-content { flex-direction: column-reverse; align-items: flex-start; gap: 1rem; }
    }
</style>